# Número de WhatsApp sin + ni espacios (ej: 5491112345678)
VITE_WHATSAPP_NUMBER=5491112345678

# Nombre de la tienda (aparece en el navbar y footer)
VITE_STORE_NAME=[NOMBRE DE LA TIENDA]

# Contraseña del panel administrativo (ruta /admin)
VITE_ADMIN_PASSWORD=admin123

# ─── Supabase (dejar vacío mientras el proyecto sea solo frontend) ─────────────
# URL del proyecto: Supabase Dashboard → Settings → API → Project URL
VITE_SUPABASE_URL=

# Anon/public key: Supabase Dashboard → Settings → API → anon public
VITE_SUPABASE_ANON_KEY=

# Service Role key — SOLO para el script seed.js, NUNCA en el frontend
# Supabase Dashboard → Settings → API → service_role secret
VITE_SUPABASE_SERVICE_KEY=
